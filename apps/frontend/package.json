{
  "name": "@oktomusic/frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "license": "AGPL-3.0-only",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "pnpm -w exec eslint -c eslint.config.ts apps/frontend",
    "lint:fix": "pnpm -w exec eslint -c eslint.config.ts --fix apps/frontend",
    "po:extract": "lingui extract",
    "po:extract:watch": "lingui extract --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:debug": "vitest --inspect-brk --inspect --single-thread --no-file-parallelism",
    "codegen": "graphql-codegen --config codegen.ts",
    "pwa-assets": "pwa-assets-generator"
  },
  "dependencies": {
    "@apollo/client": "^4.1.6",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@headlessui/react": "^2.2.9",
    "@headlessui/tailwindcss": "^0.2.2",
    "@lingui/detect-locale": "^5.9.3",
    "@oktomusic/api-schemas": "workspace:^",
    "@tailwindcss/vite": "^4.2.2",
    "axios": "^1.13.6",
    "graphql": "^16.13.2",
    "graphql-ws": "6.0.7",
    "jotai": "^2.19.0",
    "jotai-babel": "^0.1.0",
    "jotai-devtools": "^0.13.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "react-router": "^7.13.2",
    "tailwindcss": "^4.2.2",
    "temporal-polyfill": "catalog:default"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@graphql-codegen/cli": "6.2.1",
    "@graphql-codegen/client-preset": "5.2.4",
    "@lingui/babel-plugin-lingui-macro": "^5.9.3",
    "@lingui/cli": "^5.9.3",
    "@lingui/core": "^5.9.3",
    "@lingui/react": "^5.9.3",
    "@lingui/vite-plugin": "^5.9.3",
    "@oktomusic/vite-sri-manifest": "workspace:^",
    "@rolldown/plugin-babel": "^0.2.2",
    "@types/babel__core": "^7.20.5",
    "@types/node": "catalog:default",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "typescript": "catalog:default",
    "vite": "^8.0.2",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.1",
    "workbox-cacheable-response": "^7.4.0",
    "workbox-core": "^7.4.0",
    "workbox-expiration": "^7.4.0",
    "workbox-precaching": "^7.4.0",
    "workbox-range-requests": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0",
    "workbox-window": "^7.4.0"
  }
