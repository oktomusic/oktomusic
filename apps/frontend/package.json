{
  "name": "@oktomusic/frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "license": "AGPL-3.0-only",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "pnpm -w exec eslint --flag unstable_native_nodejs_ts_config -c eslint.config.ts apps/frontend",
    "lint:fix": "pnpm -w exec eslint --flag unstable_native_nodejs_ts_config -c eslint.config.ts --fix apps/frontend",
    "po:extract": "lingui extract",
    "po:extract:watch": "lingui extract --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:debug": "vitest --inspect-brk --inspect --single-thread --no-file-parallelism",
    "codegen": "graphql-codegen --config codegen.ts",
    "pwa-assets": "pwa-assets-generator"
  },
  "dependencies": {
    "@apollo/client": "^4.2.2",
    "@base-ui/react": "^1.5.0",
    "@dnd-kit/react": "^0.4.0",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@lingui/detect-locale": "^6.2.0",
    "@oktomusic/api-schemas": "workspace:^",
    "@tailwindcss/vite": "^4.3.0",
    "graphql": "^16.14.1",
    "graphql-ws": "6.0.8",
    "jotai": "^2.20.0",
    "jotai-babel": "^0.2.0",
    "jotai-devtools": "^0.14.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "react-router": "^7.17.0",
    "tailwindcss": "^4.3.0",
    "temporal-polyfill": "catalog:default"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@graphql-codegen/cli": "6.3.1",
    "@graphql-codegen/client-preset": "5.3.0",
    "@lingui/babel-plugin-lingui-macro": "^6.2.0",
    "@lingui/cli": "^6.2.0",
    "@lingui/core": "^6.2.0",
    "@lingui/react": "^6.2.0",
    "@lingui/vite-plugin": "^6.2.0",
    "@oktomusic/vite-sri-manifest": "workspace:^",
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/babel__core": "^7.20.5",
    "@types/node": "catalog:default",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/devtools": "^0.3.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "babel-plugin-react-compiler": "^1.0.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "typescript": "catalog:default",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8",
    "workbox-cacheable-response": "^7.4.1",
    "workbox-core": "^7.4.1",
    "workbox-expiration": "^7.4.1",
    "workbox-precaching": "^7.4.1",
    "workbox-range-requests": "^7.4.1",
    "workbox-routing": "^7.4.1",
    "workbox-strategies": "^7.4.1",
    "workbox-window": "^7.4.1"
  }
}
