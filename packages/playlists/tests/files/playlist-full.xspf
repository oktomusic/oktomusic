<?xml version="1.0" encoding="UTF-8"?>
<playlist version="1" xmlns="http://xspf.org/ns/0/">
  <title>XSPF example</title>
  <creator>Name of playlist author</creator>
  <annotation>Super playlist</annotation>
  <info>http://example.com/</info>
  <location>http://example.com/</location>
  <identifier>http://example.com/</identifier>
  <image>http://example.com/</image>
  <date>2005-01-08T17:10:47-05:00</date>
  <license>http://example.com/</license>
  <attribution>
    <identifier>http://example.com/</identifier>
    <location>http://example.com/</location>
  </attribution>
  <link rel="http://example.com/rel/1/">http://example.com/body/1/</link>
  <link rel="http://example.com/rel/2/">http://example.com/body/2/</link>
  <meta rel="http://example.com/rel/1/">my meta 14</meta>
  <meta rel="http://example.com/rel/2/">345</meta>
  <trackList>
    <track>
      <location>http://example.com/1.ogg</location>
      <location>http://example.com/2.mp3</location>
      <identifier>http://example.com/1/</identifier>
      <identifier>http://example.com/2/</identifier>
      <title>Track title</title>
      <creator>Artist name</creator>
      <annotation>Some text</annotation>
      <info>http://example.com/</info>
      <image>http://example.com/</image>
      <album>Album name</album>
      <trackNum>1</trackNum>
      <duration>0</duration>
      <link rel="http://example.com/rel/1/">http://example.com/body/1/</link>
      <link rel="http://example.com/rel/2/">http://example.com/body/2/</link>
      <meta rel="http://example.com/rel/1/">my meta 14</meta>
      <meta rel="http://example.com/rel/2/">345</meta>
    </track>
  </trackList>
</playlist>
